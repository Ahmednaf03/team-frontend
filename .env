# ─────────────────────────────────────────────────────────────
#  Frontend Environment Variables  (Create React App)
#  Copy this file to .env and fill in your values.
#  All variables MUST be prefixed with REACT_APP_ to be exposed.
#  Restart the dev server after any change to this file.
# ─────────────────────────────────────────────────────────────

# Backend base URL (no trailing slash)
# Development: point directly to your PHP backend
REACT_APP_API_BASE_URL=http://localhost/team-backend/api

# Root domain for subdomain-based tenant detection
# Production example: healthapp.com  → apollo.healthapp.com detects "apollo"
# Development:        localhost       → uses REACT_APP_TENANT_CODE fallback
REACT_APP_APP_DOMAIN=localhost

# Tenant code for local development (sent as X-Tenant-ID header)
# Change this to match the tenant_code in your clinic_master_db
REACT_APP_TENANT_CODE=clinic_a 


ALLOWED_HOSTS=.localhost